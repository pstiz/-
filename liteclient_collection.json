{
  "info": {
    "name": "Food Ordering System — My APIs",
    "_postman_id": "food-ordering-my-apis-2024",
    "description": "API tests สำหรับส่วนที่รับผิดชอบ: Login_admin, Login_cooks, register_cook, Login_customers, check_customers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [

    {
      "name": "1. Admin — Login_admin.html",
      "item": [

        {
          "name": "GET /admin/login — load page",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/admin/login",
              "host": ["{{base}}"],
              "path": ["admin", "login"]
            },
            "description": "โหลดหน้า login_admin → expect 200 + file: login_admin.html"
          }
        },

        {
          "name": "GET /password/:raw — generate hash (เซ็ต admin ครั้งแรก)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/password/1234",
              "host": ["{{base}}"],
              "path": ["password", "1234"]
            },
            "description": "สร้าง hashed password → expect 200 + text: hashed string"
          }
        },

        {
          "name": "✅ POST /admin/signin — success (200)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base}}/admin/signin",
              "host": ["{{base}}"],
              "path": ["admin", "signin"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_id\": \"admin01\",\n  \"password\": \"1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "expect 200 → text: redirect path เช่น '/admin/dashboard.html'"
          }
        },

        {
          "name": "❌ POST /admin/signin — wrong password (401)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base}}/admin/signin",
              "host": ["{{base}}"],
              "path": ["admin", "signin"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_id\": \"admin01\",\n  \"password\": \"wrongpass\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "expect 401 → text: 'Wrong name' or 'Wrong ID'"
          }
        },

        {
          "name": "GET /admin/logout",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/admin/logout",
              "host": ["{{base}}"],
              "path": ["admin", "logout"]
            },
            "description": "expect 200 → file: login_admin.html"
          }
        }

      ]
    },

