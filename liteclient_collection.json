    {
      "name": "5. Customers — check_customers.html",
      "item": [

        {
          "name": "GET /customers/orders — load page",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/customers/orders",
              "host": ["{{base}}"],
              "path": ["customers", "orders"]
            },
            "description": "โหลดหน้า check → expect 200 + file: check_customers.html"
          }
        },

        {
          "name": "✅ GET /customers/orders?table=4 — get all orders (200)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/customers/orders?table=4",
              "host": ["{{base}}"],
              "path": ["customers", "orders"],
              "query": [
                { "key": "table", "value": "4" }
              ]
            },
            "description": "expect 200 → JSON array [{ order_id, table_number, menu_id, quantity, status }]"
          }
        },

        {
          "name": "✅ GET /customers/orders?table=4&status=pending — filter pending",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/customers/orders?table=4&status=pending",
              "host": ["{{base}}"],
              "path": ["customers", "orders"],
              "query": [
                { "key": "table", "value": "4" },
                { "key": "status", "value": "pending" }
              ]
            },
            "description": "expect 200 → JSON array เฉพาะ status=pending"
          }
        },

        {
          "name": "❌ GET /customers/orders — missing table param (400)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/customers/orders",
              "host": ["{{base}}"],
              "path": ["customers", "orders"]
            },
            "description": "expect 400 → text: 'Missing table parameter'"
          }
        },

        {
          "name": "✅ GET /customers/orders/101 — get order detail (200)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/customers/orders/101",
              "host": ["{{base}}"],
              "path": ["customers", "orders", "101"]
            },
            "description": "expect 200 → JSON { order_id, table_number, menu_name, quantity, status }"
          }
        },

        {
          "name": "❌ GET /customers/orders/99999 — not found (404)",
